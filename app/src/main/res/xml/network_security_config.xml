<?xml version="1.0" encoding="utf-8"?>
<!--
  Config base (release): solo HTTPS, sin cleartext.
  La variante debug en src/debug/res/xml/ sobreescribe este fichero
  para permitir HTTP local contra el backend de desarrollo.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
