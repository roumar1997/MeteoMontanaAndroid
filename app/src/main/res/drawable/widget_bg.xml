<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo del widget: papel Cumbre con esquinas redondeadas y borde fino.
     Drawable en vez de GlanceModifier.cornerRadius() porque cornerRadius
     solo funciona en Android 12+ y queremos esquinas también en 11. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <solid android:color="@color/widget_bg" />
    <stroke android:width="1dp" android:color="@color/widget_stroke" />
</shape>
