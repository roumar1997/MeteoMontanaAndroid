        android:scaleX="0.5"
        android:scaleY="0.5"
        android:pivotX="12"
        android:pivotY="12">
        <path
            android:fillColor="#C2410C"
            android:pathData="M14,6 L20.5,19 L9,19 Z" />
        <path
            android:fillColor="#C2410C"
            android:pathData="M8.5,9 L13.5,19 L3.5,19 Z" />
