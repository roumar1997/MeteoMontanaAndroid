<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon (API 26+, nuestro minSdk). El artwork va como background
  full-bleed: el launcher aplica su máscara (círculo/squircle) encima y el
  icono ocupa todo el espacio. Antes solo había PNGs legacy circulares con
  margen transparente y el launcher los encogía dentro de su propia máscara.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/launcher_full" />
    <foreground android:drawable="@drawable/launcher_fg_empty" />
</adaptive-icon>
