# IntelliJ / Android Studio
*.iml
.idea/

# Gradle
.gradle/
local.properties
/build
/app/build
/shared/build
/captures
.externalNativeBuild
.cxx

# Sistema
.DS_Store
Thumbs.db

# Logs
*.log

# Ficheros temporales (p. ej. mensajes de commit COMMIT_MSG.tmp)
*.tmp

# Keystore (firmas de release) — con *.* para atrapar también sufijos
# como meteomontana-release.jks.OLD-... (NUNCA debe ir a git)
*.jks
*.jks.*
*.keystore
*.keystore.*
keystore.properties

# Reportes
/reports/
/lint-results.html

# Cache KMP/Kotlin metadata (se regenera al build)
.kotlin/

# Worktrees temporales de Claude (no van a main)
.claude/worktrees/
.clone/

# Firebase service account (NO subir a git)
**/serviceAccountKey.json

# Firebase Android config (lleva API keys) — se inyecta en CI con el secret
# GOOGLE_SERVICES_JSON; en local cada quien pone el suyo.
app/google-services.json

# Firebase iOS config (lleva API keys) — igual que google-services.json
iosApp/iosApp/GoogleService-Info.plist

# Generados por XcodeGen / xcodebuild (no versionar, se regeneran)
iosApp/MeteoMontana.xcodeproj/
iosApp/build/
iosApp/iosApp/Info.plist
# Generado por XcodeGen desde project.yml (entitlements.properties).
iosApp/iosApp/MeteoMontana.entitlements
